# 小巨蛋智能体 XJD Agent — 环境变量配置
# 复制为 .env 并填入你的 API Key

# ═══════════════════════════════════════════
#  主模型 (必填，选一个 Provider)
# ═══════════════════════════════════════════

# --- OpenAI ---
# XJD_PRIMARY_PROVIDER=openai
# XJD_PRIMARY_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# --- Anthropic ---
# XJD_PRIMARY_PROVIDER=anthropic
# XJD_PRIMARY_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

# --- DeepSeek ---
# XJD_PRIMARY_PROVIDER=deepseek
# XJD_PRIMARY_MODEL=deepseek-chat
# XJD_PRIMARY_API_KEY=sk-...

# --- Google Gemini ---
# XJD_PRIMARY_PROVIDER=google
# XJD_PRIMARY_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=...

# --- SiliconFlow (硅基流动) ---
# XJD_PRIMARY_PROVIDER=siliconflow
# XJD_PRIMARY_MODEL=Qwen/Qwen2.5-72B-Instruct
# XJD_PRIMARY_API_KEY=sk-...

# --- Groq ---
# XJD_PRIMARY_PROVIDER=groq
# XJD_PRIMARY_MODEL=llama-3.3-70b-versatile
# XJD_PRIMARY_API_KEY=gsk_...

# ═══════════════════════════════════════════
#  便宜模型 (可选，简单问题自动降级)
# ═══════════════════════════════════════════
# XJD_CHEAP_PROVIDER=deepseek
# XJD_CHEAP_MODEL=deepseek-chat

# ═══════════════════════════════════════════
#  凭证池 (可选，多 Key 轮转)
# ═══════════════════════════════════════════
# 在 config.yaml 中配置 api_keys 列表

# ═══════════════════════════════════════════
#  Gateway / Web
# ═══════════════════════════════════════════
# XJD_GATEWAY_PORT=18789
# XJD_WEB_PORT=8080

# ═══════════════════════════════════════════
#  消息平台 (按需配置)
# ═══════════════════════════════════════════

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=123456:ABCdef...

# --- Discord ---
# DISCORD_BOT_TOKEN=MTI...

# --- Slack ---
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# --- 微信 ---
# WECHAT_APP_ID=wx...
# WECHAT_APP_SECRET=...
# WECHAT_TOKEN=...

# --- 飞书 ---
# FEISHU_APP_ID=cli_...
# FEISHU_APP_SECRET=...

# --- 钉钉 ---
# DINGTALK_APP_KEY=...
# DINGTALK_APP_SECRET=...

# ═══════════════════════════════════════════
#  Redis (可选，生产环境推荐)
# ═══════════════════════════════════════════
# REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
#  日志
# ═══════════════════════════════════════════
# XJD_LOG_LEVEL=INFO
